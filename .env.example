# Local all-in-one template. Per-service + shared splits: docs/env/
# Set PORT for the service you run (Hub 3000, Webhook 3001, Processor 3002, Sender 3003, Scheduler 3004, Analytics 3005).
PORT=3000
HUB_PUBLIC_BASE_URL=http://localhost:3000
WEBHOOK_PUBLIC_BASE_URL=http://localhost:3001
MONGODB_URI=mongodb://localhost:27017/x-executor-hub
REDIS_URL=redis://localhost:6379
# REDIS_URL=${{Redis.REDIS_URL}}
# REDIS_PASSWORD=${{Redis.REDIS_PASSWORD}}
NATS_URL=nats://localhost:4222
# Subjects, durables, streams: libs/nats-js/src/nats.constants.ts
GETXAPI_API_KEY=
GETXAPI_BASE_URL=https://api.getxapi.com
GETXAPI_RATE_CAPACITY=5
GETXAPI_RATE_LEAK_INTERVAL_MS=1000
GETXAPI_RATE_JITTER_MIN_MS=100
GETXAPI_RATE_JITTER_MAX_MS=500
GETXAPI_RATE_REDIS_PREFIX=getxapi:rate
GETXAPI_RATE_QUEUE_POLL_MS=100
GETXAPI_RATE_TICKET_TTL_SEC=300
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
DEFAULT_UNKNOWN_REPLY=I don't know
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
TOKEN_ENCRYPTION_KEY=
X_API_KEY=
X_API_KEY_SECRET=
X_REDIRECT_URI=http://localhost:3000/xbot/v1/api/oauth/x/callback
X_REGISTER_WEBHOOKS_WITH_X=true
# X_WEBHOOK_CONFIG_ID=
# Must match frontend /oauth/success (see x-executor-frontend README)
OAUTH_SUCCESS_REDIRECT_URL=
# OAUTH_SUCCESS_REDIRECT_URL=http://localhost:5173/oauth/success
