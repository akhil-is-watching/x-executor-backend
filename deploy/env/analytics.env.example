# Campaign analytics — merge with docs/env/shared.env.example
# Railway: create a service, config file /docs/railway/analytics/railway.toml.
# No public HTTP API required; campaign status is queried via Hub:
# GET /xbot/v1/api/orgs/:orgId/campaigns/:campaignId/status

# Railway sets PORT automatically.
# PORT=3005

# Same MongoDB as Hub (campaigns + campaign_jobs)
# MONGODB_URI=${{MongoDB.MONGO_URL}}

# Same NATS as Scheduler and Sender (consumes x.campaign.analytics)
# NATS_URL=nats://${{Nats.RAILWAY_PRIVATE_DOMAIN}}:4222
