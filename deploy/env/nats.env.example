# NATS service (Railway) — attach docs/railway/nats-js/railway.toml to a dedicated service.
# No public domain required; other services connect over the private network.
#
# Mount a volume at /data so JetStream streams survive redeploys.
# PORT=8222 points Railway healthchecks at the HTTP monitor (client traffic uses 4222).
#
# Stream names, subjects, durables, and DLQ routing are code constants in
# libs/nats-js/src/nats.constants.ts (provisioned on app startup).

PORT=8222

NATS_URL=nats://${{Nats.RAILWAY_PRIVATE_DOMAIN}}:4222
