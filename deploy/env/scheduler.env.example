# Campaign scheduler — merge with docs/env/shared.env.example
# Railway: create a service, config file /docs/railway/scheduler/railway.toml.
# Scheduler has no public HTTP API requirement; domain optional.

# Railway sets PORT automatically.
# PORT=3004

# Same MongoDB as Hub (campaigns + campaign_jobs + x_connections)
# MONGODB_URI=${{MongoDB.MONGO_URL}}

# Same NATS as Hub, Sender, Analytics (consumes x.campaign.created)
# NATS_URL=nats://${{Nats.RAILWAY_PRIVATE_DOMAIN}}:4222

# Anti-detection send pacing (optional — defaults shown)
CAMPAIGN_HOURLY_LIMIT_PER_ACCOUNT=15
CAMPAIGN_DAILY_LIMIT_PER_ACCOUNT=80
CAMPAIGN_MIN_SEND_DELAY_MS=90000
CAMPAIGN_MAX_SEND_DELAY_MS=300000
CAMPAIGN_GLOBAL_MIN_GAP_MS=5000
