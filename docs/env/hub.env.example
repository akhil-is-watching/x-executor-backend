# Hub API — merge with docs/env/shared.env.example
# Railway: create a service, config file /docs/railway/hub/railway.toml, generate a public domain.

# Railway sets PORT automatically; do not hardcode in production.
# PORT=3000

# Public URLs (use https + Railway domains in production)
HUB_PUBLIC_BASE_URL=http://localhost:3000
# HUB_PUBLIC_BASE_URL=https://${{Hub.RAILWAY_PUBLIC_DOMAIN}}

WEBHOOK_PUBLIC_BASE_URL=http://localhost:3001
# WEBHOOK_PUBLIC_BASE_URL=https://${{Webhook.RAILWAY_PUBLIC_DOMAIN}}

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# 32 bytes, base64-encoded (openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=

# X OAuth (developer portal)
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/api/v1/oauth/x/callback
# X_REDIRECT_URI=https://${{Hub.RAILWAY_PUBLIC_DOMAIN}}/api/v1/oauth/x/callback
X_OAUTH_SCOPES=tweet.read tweet.write users.read offline.access
# Frontend URL after X OAuth (required for browser users — not optional in production)
OAUTH_SUCCESS_REDIRECT_URL=
# OAUTH_SUCCESS_REDIRECT_URL=https://your-frontend.vercel.app/oauth/success
