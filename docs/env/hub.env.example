# Hub API — merge with docs/env/shared.env.example
# Railway: create a service, config file /docs/railway/hub/railway.toml, generate a public domain.

# Railway sets PORT automatically; do not hardcode in production.
# PORT=3000

# Public URLs (use https + Railway domains in production)
HUB_PUBLIC_BASE_URL=http://localhost:3000
# HUB_PUBLIC_BASE_URL=https://${{Hub.RAILWAY_PUBLIC_DOMAIN}}

WEBHOOK_PUBLIC_BASE_URL=http://localhost:3001
# WEBHOOK_PUBLIC_BASE_URL=https://${{Webhook.RAILWAY_PUBLIC_DOMAIN}}

# Auth
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# 32 bytes, base64-encoded (openssl rand -base64 32)
TOKEN_ENCRYPTION_KEY=

# X OAuth 1.0a — user connect + app bearer + Account Activity subscriptions
# Developer Portal → your app → Keys and tokens → Consumer Keys
# Enable OAuth 1.0a, Read/Write/DM permissions, add X_REDIRECT_URI as callback URL
X_API_KEY=
X_API_KEY_SECRET=
X_REDIRECT_URI=http://localhost:3000/xbot/v1/api/hub/oauth/x/callback
# X_REDIRECT_URI=https://${{Hub.RAILWAY_PUBLIC_DOMAIN}}/xbot/v1/api/hub/oauth/x/callback

# Shared ingress: {WEBHOOK_PUBLIC_BASE_URL}/xbot/v1/api/webhook/incoming — register once + subscribe per OAuth (default on)
X_REGISTER_WEBHOOKS_WITH_X=true
# X_WEBHOOK_CONFIG_ID=

# Webhook service CRC: set X_CONSUMER_SECRET (or X_API_KEY_SECRET) on Webhook service

# LLM (prompt test + same model as Processor DM replies)
OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini

# Frontend URL after X OAuth (required for browser users — not optional in production)
OAUTH_SUCCESS_REDIRECT_URL=
# OAUTH_SUCCESS_REDIRECT_URL=https://your-frontend.vercel.app/oauth/success

# Webshare proxy pool — required when proxy-per-account is enabled
# Sign up at https://webshare.io, API key at https://proxy.webshare.io/userapi/token
WEBSHARE_API_KEY=
