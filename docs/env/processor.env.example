# DM processor — merge with docs/env/shared.env.example
# Railway: create a service, config file /docs/railway/processor/railway.toml.
# Processor has no public HTTP API requirement; domain optional.

# Railway sets PORT automatically.
# PORT=3002

# Same key as hub (base64, 32 decoded bytes)
TOKEN_ENCRYPTION_KEY=

# X App OAuth 1.0a Consumer Keys (same values as Hub X_API_KEY / X_API_KEY_SECRET)
# Required for XChat unlock: GET /2/users/:id/public_keys (Juicebox config)
X_API_KEY=
X_API_KEY_SECRET=

# GetXAPI
GETXAPI_API_KEY=
GETXAPI_BASE_URL=https://api.getxapi.com
GETXAPI_RATE_CAPACITY=5
GETXAPI_RATE_LEAK_INTERVAL_MS=1000
GETXAPI_RATE_JITTER_MIN_MS=100
GETXAPI_RATE_JITTER_MAX_MS=500
GETXAPI_RATE_REDIS_PREFIX=getxapi:rate
GETXAPI_RATE_QUEUE_POLL_MS=100
GETXAPI_RATE_TICKET_TTL_SEC=300

# OpenAI
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
DEFAULT_UNKNOWN_REPLY=I don't know
