# Shared infrastructure — copy into each Railway service (or use Railway shared variables).
# See docs/railway.md for plugin wiring and cross-service references.

# MongoDB (Railway MongoDB plugin)
MONGODB_URI=mongodb://localhost:27017/x-executor-hub
# MONGODB_URI=${{MongoDB.MONGO_URL}}

# Redis (Railway Redis plugin — must include password in production)
REDIS_URL=redis://localhost:6379
# Full URL with auth (preferred; copy from the Redis service variables tab):
# REDIS_URL=${{Redis.REDIS_URL}}
# If REDIS_URL has no password, set these (Railway also exposes REDIS_PASSWORD):
# REDIS_PASSWORD=${{Redis.REDIS_PASSWORD}}
# REDIS_USERNAME=default

# NATS (Railway: docs/railway/nats-js/railway.toml — subjects/durables in libs/nats-js/src/nats.constants.ts)
NATS_URL=nats://localhost:4222
# NATS_URL=nats://${{Nats.RAILWAY_PRIVATE_DOMAIN}}:4222
