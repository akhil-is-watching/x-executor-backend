# Webhook ingress — merge with docs/env/shared.env.example
# Railway: create a service, config file /docs/railway/webhook/railway.toml, generate a public domain.

# Railway sets PORT automatically.
# PORT=3001

# Must match the host registered for incoming X webhooks (no trailing slash)
WEBHOOK_PUBLIC_BASE_URL=http://localhost:3001
# WEBHOOK_PUBLIC_BASE_URL=https://${{Webhook.RAILWAY_PUBLIC_DOMAIN}}

# CRC + POST signatures ONLY — use OAuth 1.0 Consumer Secret (paired with Consumer Key).
# Set ONE secret on the Webhook service. If both are set, X_CONSUMER_SECRET wins.
# Do not copy Hub's OAuth 2.0 Client Secret here unless CRC already passes with it.
X_CONSUMER_SECRET=
# Optional fallback when X_CONSUMER_SECRET is unset (prefer unsetting this on Webhook)
# X_CLIENT_SECRET=
