{
  "name": "x-executor",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/x-executor/main",
    "start:hub": "nest start hub",
    "start:hub:dev": "nest start hub --watch",
    "build:hub": "nest build hub",
    "start:webhook": "nest start webhook",
    "start:webhook:dev": "nest start webhook --watch",
    "build:webhook": "nest build webhook",
    "start:processor": "nest start processor",
    "start:processor:dev": "nest start processor --watch",
    "build:processor": "nest build processor",
    "start:sender": "nest start sender",
    "start:sender:dev": "nest start sender --watch",
    "build:sender": "nest build sender",
    "start:hub:prod": "node dist/apps/hub/main",
    "start:webhook:prod": "node dist/apps/webhook/main",
    "start:processor:prod": "node dist/apps/processor/main",
    "start:sender:prod": "node dist/apps/sender/main",
    "start:scheduler": "nest start scheduler",
    "start:scheduler:dev": "nest start scheduler --watch",
    "build:scheduler": "nest build scheduler",
    "start:scheduler:prod": "node dist/apps/scheduler/main",
    "start:analytics": "nest start analytics",
    "start:analytics:dev": "nest start analytics --watch",
    "build:analytics": "nest build analytics",
    "start:analytics:prod": "node dist/apps/analytics/main",
    "test:hub:e2e": "jest --config ./apps/hub/test/jest-e2e.json",
    "test:webhook:e2e": "jest --config ./apps/webhook/test/jest-e2e.json",
    "test:services:health:e2e": "jest --config ./apps/processor/test/jest-e2e.json && jest --config ./apps/sender/test/jest-e2e.json && jest --config ./apps/scheduler/test/jest-e2e.json && jest --config ./apps/analytics/test/jest-e2e.json",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/x-executor/test/jest-e2e.json",
    "xchat:decrypt-poc": "node scripts/xchat-decrypt-poc.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.0",
    "mongoose": "^9.6.3",
    "nats": "^2.29.3",
    "openai": "^6.42.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twitter-api-v2": "^1.29.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@higuchan123/twitter_lib": "^1.0.5",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "^@app/getxapi(|/.*)$": "<rootDir>/libs/getxapi/src/$1",
      "^@app/llm(|/.*)$": "<rootDir>/libs/llm/src/$1",
      "^@app/nats-js(|/.*)$": "<rootDir>/libs/nats-js/src/$1",
      "^@app/redis(|/.*)$": "<rootDir>/libs/redis/src/$1",
      "^@app/shared(|/.*)$": "<rootDir>/libs/shared/src/$1"
    }
  }
}
